# Mailbox environment variables
# Copy to .env and fill in your values: cp .env.example .env
# Never commit .env — it holds secrets.

# --- Kit (kit.com) v4 API ---
# Create a V4 API key in your Kit account under Settings → Developer.
# Used for personal/account automation. See docs/KitAPI.md.
KIT_API_KEY=

# Base URL for the Kit v4 API. Override only for testing against a mock server.
KIT_API_BASE_URL=https://api.kit.com/v4

# Optional: request timeout (seconds) and max retries for transient failures.
KIT_API_TIMEOUT=30
KIT_API_MAX_RETRIES=3

# --- OAuth (only if/when this app acts as a public Kit integration) ---
# Leave blank for API-key auth. OAuth raises the rate limit from 120 to 600
# requests per rolling 60s. See docs/KitAPI.md.
KIT_OAUTH_CLIENT_ID=
KIT_OAUTH_CLIENT_SECRET=
